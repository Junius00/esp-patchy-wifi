# NAT gateway requirements
CONFIG_LWIP_IP_FORWARD=y
CONFIG_LWIP_IPV4_NAPT=y
CONFIG_LWIP_L2_TO_L3_COPY=y

# Wi-Fi: AP+STA coexistence
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=y

# Bluetooth (NimBLE) for provisioning BLE transport
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=n

# rmaker_app_network: BLE transport + QR display
CONFIG_APP_NETWORK_PROV_TRANSPORT_BLE=y
CONFIG_APP_NETWORK_PROV_SHOW_QR=y
CONFIG_APP_NETWORK_PROV_NAME_PREFIX="PATCHY"
# Auto-stop provisioning after N minutes (0 = never)
CONFIG_APP_NETWORK_PROV_TIMEOUT_PERIOD=0

# Custom partition table for NVS headroom
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# FreeRTOS headroom
CONFIG_ESP_MAIN_TASK_STACK_SIZE=5120
